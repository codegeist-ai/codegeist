flowchart LR
    User[User or process args]
    Boot[Spring Boot ApplicationRunner]
    Runner[ShellRunner]
    Interactive[InteractiveShellRunner]
    NonInteractive[NonInteractiveShellRunner]
    Parser[CommandParser]
    Parsed[ParsedInput]
    Registry[CommandRegistry]
    Executor[CommandExecutor]
    Context[CommandContext]
    Command[Command]
    Output[Output writer]
    Input[Input reader]

    User --> Boot
    Boot --> Runner
    Runner --> Interactive
    Runner --> NonInteractive
    Interactive --> Parser
    NonInteractive --> Parser
    Parser --> Parsed
    Parsed --> Context
    Registry --> Context
    Context --> Executor
    Executor --> Command
    Command --> Output
    Command --> Input

    AutoConfig[CommandRegistryAutoConfiguration]
    Annotated[@Command methods]
    Programmatic[Command beans]
    Quit[Quit command]

    AutoConfig --> Registry
    Annotated --> AutoConfig
    Programmatic --> AutoConfig
    Quit --> AutoConfig

