{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::codegeist-artifacts"
      ],
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "accounts/codegeist-smoke/artifacts/commands/*"
          ]
        }
      }
    },
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::codegeist-artifacts/accounts/codegeist-smoke/artifacts/commands/*"
      ]
    }
  ]
}
